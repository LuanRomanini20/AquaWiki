# Arquivo .gitignore para projeto web

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Logs
logs/
*.log

# Runtime
pids/
*.pid
*.seed
*.pid.lock

# Coverage / reports
coverage/
.nyc_output/

# Build outputs
dist/
build/
.out/
.cache/
.parcel-cache/
.next/
public/build/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDEs and editors
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Environment variables
.env
.env.local
.env.*.local

# Misc
.sass-cache/
bower_components/
*.swp
*.tmp
npm-debug.log
